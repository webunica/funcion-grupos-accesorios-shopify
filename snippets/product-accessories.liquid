{% comment %}
  Snippet: product-accessories.liquid
  Usage: {% render 'product-accessories', product: product %}
{% endcomment %}

{% assign accessories = product.metafields.custom.accessories.value %}

{% if accessories != blank %}
<div class="product-accessories-container" id="product-accessories-{{ product.id }}">
  <h3 class="product-accessories-title">{{ 'Configura tu producto' | escape }}</h3>
  
  {% comment %} Agrupar accesorios por su tipo de producto (ej. Patas, Brazos, Accesorios) {% endcomment %}
  {% assign accessory_types = "" %}
  {% for accessory in accessories %}
    {% unless accessory_types contains accessory.type %}
      {% capture accessory_types %}{{ accessory_types }}{% if accessory_types != "" %}|{% endif %}{{ accessory.type }}{% endcapture %}
    {% endunless %}
  {% endfor %}
  {% assign type_array = accessory_types | split: "|" %}

  <div class="product-accessories-groups">
    {% for type in type_array %}
      <div class="accessory-group" data-group-type="{{ type | handle }}">
        <h4 class="accessory-group-title">{{ type }}</h4>
        <div class="accessory-group-items">
          {% for accessory in accessories %}
            {% if accessory.type == type and accessory.available %}
              {% assign variant = accessory.first_available_variant %}
              <div class="product-accessory-item" data-variant-id="{{ variant.id }}">
                <div class="accessory-input-wrapper">
                  {% comment %} 
                    Si el tipo es "Accesorios", usamos checkbox (múltiple). 
                    Si es algo como "Patas" o "Brazos", usamos radio (selección única).
                  {% endcomment %}
                  {% if type == 'Accesorios' or type == 'Extras' %}
                    <input type="checkbox" 
                           name="accessory_{{ type | handle }}"
                           id="accessory-{{ accessory.id }}" 
                           class="accessory-input" 
                           value="{{ variant.id }}"
                           data-price="{{ variant.price }}"
                           data-group="{{ type | handle }}">
                  {% else %}
                    <input type="radio" 
                           name="accessory_{{ type | handle }}"
                           id="accessory-{{ accessory.id }}" 
                           class="accessory-input" 
                           value="{{ variant.id }}"
                           data-price="{{ variant.price }}"
                           data-group="{{ type | handle }}">
                  {% endif %}
                </div>
                
                <div class="accessory-details">
                  <label for="accessory-{{ accessory.id }}" class="accessory-label">
                    <span class="accessory-name">{{ accessory.title }}</span>
                    <span class="accessory-price">(+ {{ variant.price | money }})</span>
                  </label>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="product-accessories-summary">
    <div class="summary-row">
      <span>Precio Base:</span>
      <span>{{ product.price | money }}</span>
    </div>
    <div class="summary-row total-row">
      <span>Total Configurado:</span>
      <span class="total-price-display" data-base-price="{{ product.price }}">
        {{ product.price | money }}
      </span>
    </div>
  </div>
</div>

<style>
  .product-accessories-container {
    margin: 25px 0;
    padding: 20px;
    border: 1px solid #ddd;
    border-radius: 12px;
    background-color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .product-accessories-title {
    font-size: 1.25rem;
    margin-bottom: 20px;
    border-bottom: 2px solid #eee;
    padding-bottom: 10px;
  }
  .accessory-group {
    margin-bottom: 20px;
  }
  .accessory-group-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #333;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .accessory-group-items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  .product-accessory-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    border: 1px solid #f0f0f0;
    border-radius: 6px;
    transition: background 0.2s;
  }
  .product-accessory-item:hover {
    background-color: #fcfcfc;
  }
  .accessory-label {
    display: flex;
    justify-content: space-between;
    width: 100%;
    cursor: pointer;
  }
  .accessory-name {
    font-size: 0.95rem;
  }
  .accessory-price {
    font-size: 0.9rem;
    color: #2c6ecb;
    font-weight: 600;
  }
  .product-accessories-summary {
    margin-top: 20px;
    padding-top: 15px;
    border-top: 2px solid #eee;
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 5px;
    color: #666;
  }
  .total-row {
    font-size: 1.2rem;
    font-weight: 800;
    color: #000;
    margin-top: 10px;
  }
</style>

<script src="{{ 'product-accessories.js' | asset_url }}" defer="defer"></script>
{% endif %}
